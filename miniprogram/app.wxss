/* 旅帧 - 全局样式 */

/* 颜色变量 */
page {
  --primary: #4A90D9;
  --primary-dark: #3A7BC8;
  --success: #52C41A;
  --warning: #FAAD14;
  --danger: #FF4D4F;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-muted: #999999;
  --bg-color: #f5f5f5;
  --bg-white: #ffffff;
  --border-color: #e8e8e8;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-color);
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 0 30rpx;
  box-sizing: border-box;
}

/* Flex 布局 */
.flex {
  display: flex;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-column {
  display: flex;
  flex-direction: column;
}

/* 按钮 */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
}
.btn-primary:active {
  background: var(--primary-dark);
}

/* 卡片 */
.card {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 文字 */
.text-center { text-align: center; }
.text-muted { color: var(--text-muted); }
.text-secondary { color: var(--text-secondary); }

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 一行省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
