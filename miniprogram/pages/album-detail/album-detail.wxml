<!-- 相册详情页 -->
<view class="container">
  <!-- 顶部封面 -->
  <view class="cover-section">
    <image class="cover-img" src="{{album.cover}}" mode="aspectFill" />
    <view class="cover-info">
      <text class="cover-title">{{album.name}}</text>
      <text class="cover-desc">{{album.description}}</text>
      <view class="cover-stats flex">
        <text>📷 {{album.photoCount}}张照片</text>
        <text>📅 {{album.dateRange}}</text>
      </view>
    </view>
  </view>

  <!-- 操作栏 -->
  <view class="action-bar">
    <view class="action-btn {{liked ? 'active' : ''}}" bindtap="toggleLike">
      <text>{{liked ? '❤️' : '🤍'}}</text>
      <text>{{likeCount}}</text>
    </view>
    <view class="action-btn" bindtap="addComment">
      <text>💬</text>
      <text>评论</text>
    </view>
    <button class="action-btn" open-type="share">
      <text>↗️</text>
      <text>分享</text>
    </button>
    <view class="action-btn" bindtap="addPhoto">
      <text>➕</text>
      <text>添加</text>
    </view>
  </view>

  <!-- 照片网格 -->
  <view class="photo-grid">
    <view class="photo-item" wx:for="{{photos}}" wx:key="_id" bindtap="viewPhoto" data-index="{{index}}">
      <image class="photo-img" src="{{item.url}}" mode="aspectFill" />
      <view class="photo-info" wx:if="{{item.location}}">
        <text class="photo-location">📍 {{item.location}}</text>
      </view>
    </view>
  </view>

  <!-- 添加照片按钮 -->
  <view class="add-photo-btn" bindtap="addPhoto">
    <text>➕ 添加照片</text>
  </view>
</view>
