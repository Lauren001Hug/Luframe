/* 相册详情样式 */
.cover-section {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  color: #fff;
}
.cover-title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}
.cover-desc {
  font-size: 26rpx;
  margin-top: 10rpx;
  display: block;
  opacity: 0.9;
}
.cover-stats {
  margin-top: 16rpx;
  font-size: 24rpx;
  gap: 30rpx;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  background: #fff;
  border-bottom: 1rpx solid var(--border-color);
}
.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 30rpx;
  background: none;
  border: none;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.action-btn.active {
  color: #e91e63;
}
.action-btn text:first-child {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  padding: 20rpx 0;
}
.photo-item {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 8rpx;
}
.photo-img {
  width: 100%;
  height: 100%;
  background: #eee;
}
.photo-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx;
  background: rgba(0,0,0,0.5);
}
.photo-location {
  font-size: 20rpx;
  color: #fff;
}

/* 添加照片按钮 */
.add-photo-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  margin: 20rpx 0;
  border: 2rpx dashed var(--primary);
  border-radius: 16rpx;
  color: var(--primary);
  font-size: 30rpx;
}
